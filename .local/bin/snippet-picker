#!/bin/bash
# ~/.local/bin/snippet-picker
SNIPPETS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/snippets/work-snippets.txt"
USAGE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/snippets/usage-count.txt"

if [ ! -f "$SNIPPETS_FILE" ]; then
    notify-send "Snippet Picker" "Snippets file not found: $SNIPPETS_FILE"
    exit 1
fi

touch "$USAGE_FILE"

get_usage_count() {
    local key="$1"
    grep "^$key:" "$USAGE_FILE" 2>/dev/null | cut -d: -f2 || echo "0"
}

increment_usage() {
    local key="$1"
    local count=$(get_usage_count "$key")
    local new_count=$((count + 1))
    grep -v "^$key:" "$USAGE_FILE" > "${USAGE_FILE}.tmp" 2>/dev/null || true
    echo "$key:$new_count" >> "${USAGE_FILE}.tmp"
    mv "${USAGE_FILE}.tmp" "$USAGE_FILE"
}

# If --pick flag, run the fzf picker and write result to tmp file
if [[ "$1" == "--pick" ]]; then
    declare -A snippets_display
    declare -A snippets_text
    current_key=""
    current_display=""
    current_text=""

    while IFS= read -r line || [ -n "$line" ]; do
        if [[ "$line" =~ ^([a-z0-9]+)\|([^|]+)\|(.*)$ ]]; then
            if [[ -n "$current_key" ]]; then
                snippets_display["$current_key"]="$current_display"
                snippets_text["$current_key"]="$current_text"
            fi
            current_key="${BASH_REMATCH[1]}"
            current_display="${BASH_REMATCH[2]}"
            current_text="${BASH_REMATCH[3]}"
        elif [[ -n "$current_key" && ! "$line" =~ ^[[:space:]]*# ]]; then
            current_text+=$'\n'"$line"
        fi
    done < "$SNIPPETS_FILE"

    if [[ -n "$current_key" ]]; then
        snippets_display["$current_key"]="$current_display"
        snippets_text["$current_key"]="$current_text"
    fi

    declare -A display_with_length
    for key in "${!snippets_display[@]}"; do
        key_length=${#key}
        padded_length=$(printf "%02d" "$key_length")
        display_with_length["${padded_length}-${key}"]="$key - ${snippets_display[$key]}"
    done

    display_list=""
    for sort_key in $(printf '%s\n' "${!display_with_length[@]}" | sort); do
        display_list+="${display_with_length[$sort_key]}"$'\n'
    done

    selected=$(echo -n "$display_list" | fzf \
        --prompt="  Snippet > " \
        --layout=reverse \
        --border=rounded \
        --no-info \
        --no-scrollbar)

    [[ -z "$selected" ]] && exit 0

    echo "$selected" > /tmp/snippet-selected
    exit 0
fi

# Launch alacritty with --pick, wait for it to finish
alacritty --title "snippet-picker" \
           --option "font.size=11" \
           -e bash ~/.local/bin/snippet-picker --pick
wait

# Read result
[[ ! -f /tmp/snippet-selected ]] && exit 0
selected=$(cat /tmp/snippet-selected)
rm -f /tmp/snippet-selected

[[ -z "$selected" ]] && exit 0

shortcut=$(echo "$selected" | awk '{print $1}')
increment_usage "$shortcut"

# Re-parse to get snippet text
declare -A snippets_text
current_key=""
current_text=""

while IFS= read -r line || [ -n "$line" ]; do
    if [[ "$line" =~ ^([a-z0-9]+)\|([^|]+)\|(.*)$ ]]; then
        if [[ -n "$current_key" ]]; then
            snippets_text["$current_key"]="$current_text"
        fi
        current_key="${BASH_REMATCH[1]}"
        current_text="${BASH_REMATCH[3]}"
    elif [[ -n "$current_key" && ! "$line" =~ ^[[:space:]]*# ]]; then
        current_text+=$'\n'"$line"
    fi
done < "$SNIPPETS_FILE"

if [[ -n "$current_key" ]]; then
    snippets_text["$current_key"]="$current_text"
fi

snippet_text="${snippets_text[$shortcut]}"
while [[ "$snippet_text" == *$'\n' ]]; do
    snippet_text="${snippet_text%$'\n'}"
done

if [ -n "$snippet_text" ]; then
    echo -n "$snippet_text" | wl-copy
    sleep 0.2
    wtype -M ctrl v -m ctrl
else
    notify-send "Snippet Picker" "Snippet not found: $shortcut"
fi
